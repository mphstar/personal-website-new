---
import data_experience from '../models/data_experience';
import data_education from '../models/data_education';
import data_contact from '../models/data_contact';
---

<section>
  <div class="mb-8">
    <img
      src="/assets/pp.png"
      alt="Mphstar Portrait"
      class="w-24 h-24 rounded-full object-cover border-2 border-gray-100 dark:border-gray-800"
      loading="lazy"
    />
  </div>
  <h2 class="text-2xl font-semibold mb-6 dark:text-gray-100">
    Mphstar [he/him]
  </h2>
  <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-6">
    I am Bintang Malindo Eka Putra, a fresh graduate in Informatics Engineering
    from Jember State Polytechnic. I am deeply interested in Web and Mobile
    Development.
  </p>

  <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-6">
    I have work experience and stay active in various activities. Able to work
    individually and in a team, have good analysis and planning, communicative,
    easy to adapt, enthusiastic to develop, and interested in learning new
    things.
  </p>

  <h3 class="text-lg font-semibold mb-3 mt-8 dark:text-gray-100">Experience</h3>
  <div class="space-y-6">
    {data_experience.map((exp) => (
      <div class="border-l-2 border-gray-200 dark:border-gray-800 pl-4">
        <h4 class="font-medium dark:text-gray-100">{exp.role}</h4>
        <p class="text-sm text-gray-600 dark:text-gray-400 font-medium">{exp.company}</p>
        <p class="text-sm text-gray-500 dark:text-gray-500 mb-2">
          {exp.date} &bull; {exp.location}
        </p>
        {exp.descriptions.length > 0 && (
          <ul class="list-disc list-inside text-sm text-gray-700 dark:text-gray-300 space-y-1">
            {exp.descriptions.map((desc) => (
              <li>{desc}</li>
            ))}
          </ul>
        )}
      </div>
    ))}
  </div>

  <h3 class="text-lg font-semibold mb-3 mt-12 dark:text-gray-100">Education</h3>
  <div class="space-y-6">
    {data_education.map((edu) => (
      <div class="border-l-2 border-gray-200 dark:border-gray-800 pl-4">
        <h4 class="font-medium dark:text-gray-100">{edu.school}</h4>
        <p class="text-sm text-gray-500 dark:text-gray-500 mb-2">
          {edu.period}
        </p>
        <p class="text-sm text-gray-700 dark:text-gray-300">
          {edu.major}
        </p>
      </div>
    ))}
  </div>

  <h3 class="text-lg font-semibold mb-3 mt-12 dark:text-gray-100">Contact</h3>
  <div class="space-y-3">
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
      I'm excited to connect with everyone, so please don't hesitate to get in touch with me by following my contact links below:
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {data_contact.map((contact) => {
        let iconHtml = '';
        if(contact.platform === 'Email') iconHtml = '<path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />';
        if(contact.platform === 'Github') iconHtml = '<path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />';
        if(contact.platform === 'Facebook') iconHtml = '<path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" />';
        if(contact.platform === 'Instagram') iconHtml = '<path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />';
        if(contact.platform === 'LinkedIn') iconHtml = '<path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />';
        if(contact.platform === 'Youtube') iconHtml = '<path fill-rule="evenodd" d="M21.582 6.186a2.665 2.665 0 00-1.876-1.888C18.04 3.864 12 3.864 12 3.864s-6.04 0-7.706.434A2.664 2.664 0 002.418 6.186C2 7.87 2 12 2 12s0 4.13.418 5.814a2.665 2.665 0 001.876 1.888c1.666.434 7.706.434 7.706.434s6.04 0 7.706-.434a2.664 2.664 0 001.876-1.888C22 16.13 22 12 22 12s0-4.13-.418-5.814zM9.8 15.592V8.408L15.916 12 9.8 15.592z" clip-rule="evenodd" />';

        return (
          <a 
            href={contact.link}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative flex items-center gap-4 p-4 rounded-xl border border-gray-100 dark:border-gray-800/60 bg-white dark:bg-[#151515] hover:border-gray-300 dark:hover:border-gray-600 shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden"
          >
            <div class="absolute inset-0 bg-gradient-to-r from-gray-50 to-transparent dark:from-white/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            
            <div class="relative flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-gray-50 dark:bg-black border border-gray-100 dark:border-gray-800 group-hover:scale-110 transition-transform duration-300 text-gray-700 dark:text-gray-300">
              <svg class="w-5 h-5 fill-current stroke-current" stroke-width="1.5" viewBox="0 0 24 24" set:html={iconHtml} />
            </div>

            <div class="relative flex flex-col overflow-hidden">
              <span class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-0.5">{contact.platform}</span>
              <span class="text-sm font-medium truncate text-gray-900 dark:text-gray-100">{contact.value}</span>
            </div>
            
            <div class="absolute right-4 text-gray-300 dark:text-gray-700 opacity-0 group-hover:opacity-100 transform translate-x-2 group-hover:translate-x-0 transition-all duration-300">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
