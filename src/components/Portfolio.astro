---
import data from '../models/data_portfolio';
---

<section>
  <h2 class="text-2xl font-semibold mb-6 flex items-center dark:text-gray-100">
    <svg class="w-5 h-5 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
    Featured Works
  </h2>
  <div class="space-y-12">
    {data.map((item) => (
      <div class="flex flex-col">
        <h3 class="text-lg font-medium text-gray-900 dark:text-gray-100 mb-1 flex items-center group">
          {item.redirect ? (
            <a href={item.redirect as string} class="hover:underline text-black dark:text-white flex items-center" target="_blank" rel="noopener noreferrer">
              {item.title}
              <svg class="w-4 h-4 ml-1.5 text-gray-400 dark:text-gray-500 group-hover:text-black dark:group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
            </a>
          ) : (
            <span>{item.title}</span>
          )}
        </h3>

        {item.image && (
          <a href={item.image} class="gallery-trigger" data-title={item.title}>
            <img 
              src={item.image} 
              alt={item.title as string} 
              class="w-full max-h-64 object-cover border border-gray-200 dark:border-gray-800 rounded-lg drop-shadow-sm my-3 opacity-90 dark:opacity-80 hover:opacity-100 transition-opacity cursor-zoom-in"
              loading="lazy"
            />
          </a>
        )}

        <p class="text-gray-600 dark:text-gray-400 text-base leading-relaxed mb-3">
          {item.deskripsi}
        </p>
        
        <div class="flex flex-wrap gap-2 text-sm text-gray-500 dark:text-gray-400 mb-3">
          {item.build && item.build.length > 0 && item.build.map((tech) => (
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 border border-gray-200 dark:border-gray-700">
              {tech}
            </span>
          ))}
        </div>

        {item.github && (
          <div class="mt-1">
            <a href={item.github as string} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm font-medium hover:underline text-gray-800 dark:text-gray-300">
              <svg class="w-4 h-4 mr-1.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
              Source Code
            </a>
          </div>
        )}
      </div>
    ))}
  </div>
</section>
