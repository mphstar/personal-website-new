---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  return notes.map((note) => {
    // Strip the /index.md logic correctly to generate folder boundaries
    const slug = note.id.replace(/\/index$|^index$/, "");
    return {
      params: { slug },
      props: { note },
    };
  });
}

interface Props {
  note: CollectionEntry<"notes">;
}

const { note } = Astro.props;
const { Content } = await render(note);

const formattedDate = note.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout
  title={`${note.data.title} | Notes`}
  description={note.data.description || note.data.title}
>
  <article class="mt-8 md:mt-12 mb-20 animate-fade-in">
    <a
      href="/notes"
      class="inline-flex items-center text-sm text-gray-500 hover:text-black dark:hover:text-white mb-8 transition-colors group"
    >
      <svg
        class="w-4 h-4 mr-2 transform group-hover:-translate-x-1 transition-transform"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg
      >
      Back to Notes
    </a>

    <header class="mb-12">
      <h1
        class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-gray-100 mb-4"
      >
        {note.data.title}
      </h1>
      <time class="text-sm font-mono text-gray-500 flex items-center">
        <svg
          class="w-4 h-4 mr-2"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
          ></path></svg
        >
        {formattedDate}
      </time>
    </header>

    <div class="custom-prose">
      <Content />
    </div>
  </article>
</Layout>

<style is:global>
  @reference "../../styles/global.css";

  .custom-prose {
    @apply text-base leading-loose text-gray-800 dark:text-gray-300;
  }
  .custom-prose p {
    @apply mb-6;
  }
  .custom-prose h1,
  .custom-prose h2,
  .custom-prose h3,
  .custom-prose h4 {
    @apply font-bold text-gray-900 dark:text-gray-100 mt-10 mb-4;
  }
  .custom-prose h2 {
    @apply text-2xl border-b border-gray-200 dark:border-gray-800 pb-2;
  }
  .custom-prose h3 {
    @apply text-xl;
  }
  .custom-prose a {
    @apply text-black dark:text-white underline underline-offset-4 decoration-gray-300 dark:decoration-gray-700 hover:decoration-black dark:hover:decoration-white transition-colors;
  }
  .custom-prose ul {
    @apply list-disc list-outside pl-5 mb-6 space-y-2;
  }
  .custom-prose ol {
    @apply list-decimal list-outside pl-5 mb-6 space-y-2;
  }
  .custom-prose blockquote {
    @apply border-l-4 border-gray-300 dark:border-gray-700 pl-4 italic text-gray-600 dark:text-gray-400 my-6;
  }
  .custom-prose img {
    @apply rounded-xl border border-gray-200 dark:border-gray-800 my-8 w-full h-auto;
  }
  .custom-prose code {
    @apply bg-gray-100 dark:bg-[#1a1a1a] px-1.5 py-0.5 rounded text-sm border border-gray-200 dark:border-gray-800;
  }
  .custom-prose hr {
    @apply border-gray-200 dark:border-gray-800 my-10;
  }
  .custom-prose table {
    @apply w-full text-left border-collapse my-8;
  }
  .custom-prose th {
    @apply border-b-2 border-gray-200 dark:border-gray-700 pb-3 font-bold text-gray-900 dark:text-gray-100;
  }
  .custom-prose td {
    @apply border-b border-gray-100 dark:border-gray-800 py-3;
  }
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* macOS Code Block styles injected via JS */
  .mac-code-wrapper {
    @apply relative border border-gray-200 dark:border-gray-800 rounded-xl overflow-hidden my-8 bg-gray-50 dark:bg-[#0d1117] shadow-sm;
  }
  .mac-code-header {
    @apply flex items-center justify-between px-4 py-2.5 bg-gray-200/50 dark:bg-[#161b22] border-b border-gray-200 dark:border-gray-800;
  }
  .mac-code-dots {
    @apply flex space-x-1.5;
  }
  .mac-dot {
    @apply w-3 h-3 rounded-full opacity-80;
  }
  .mac-copy-btn {
    @apply text-[11px] uppercase tracking-wider font-bold px-2.5 py-1.5 rounded-md bg-white dark:bg-[#21262d] border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-[#30363d] hover:text-gray-900 dark:hover:text-white transition-all flex items-center gap-1.5 cursor-pointer shadow-sm;
  }
  .custom-prose pre {
    @apply p-5 w-full overflow-x-auto text-sm m-0 border-none rounded-none !bg-transparent leading-relaxed;
  }
  .custom-prose pre code {
    @apply !bg-transparent p-0 border-none;
  }

  /* Shiki dual theme: swap to dark colors when dark mode is active */
  html.dark .custom-prose pre,
  html.dark .custom-prose pre span {
    color: var(--shiki-dark) !important;
    background-color: transparent !important;
  }
</style>

<script>
  // Setup code blocks with macOS header and copy button
  function initCodeBlocks() {
    const codeBlocks = document.querySelectorAll('.custom-prose pre');
    
    codeBlocks.forEach((pre) => {
      // Prevent wrapping multiple times on re-renders
      if (pre.parentElement?.classList.contains('mac-code-wrapper')) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'mac-code-wrapper group';
      
      const header = document.createElement('div');
      header.className = 'mac-code-header';
      
      const dotsHTML = `
        <div class="mac-code-dots">
          <div class="mac-dot bg-red-400"></div>
          <div class="mac-dot bg-amber-400"></div>
          <div class="mac-dot bg-green-400"></div>
        </div>
      `;

      const codeRawText = pre.textContent || '';
      
      const copyBtn = document.createElement('button');
      copyBtn.className = 'mac-copy-btn opacity-0 group-hover:opacity-100 focus:opacity-100 transition-opacity';
      copyBtn.innerHTML = `
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
        Copy
      `;

      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(codeRawText);
          const originalHTML = copyBtn.innerHTML;
          copyBtn.innerHTML = `
            <svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            Copied!
          `;
          setTimeout(() => {
            copyBtn.innerHTML = originalHTML;
          }, 2000);
        } catch (err) {
          console.error("Failed to copy", err);
        }
      });

      header.innerHTML = dotsHTML;
      header.appendChild(copyBtn);
      
      pre.parentNode?.insertBefore(wrapper, pre);
      wrapper.appendChild(header);
      wrapper.appendChild(pre);
    });
  }

  // Support for Astro View Transitions (re-run on navigation)
  document.addEventListener('astro:page-load', initCodeBlocks);
</script>
