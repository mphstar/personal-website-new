---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const notes = await getCollection("notes");
notes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Notes | Mphstar"
  description="Digital garden and personal notes by Mphstar."
>
  <section class="mb-20 animate-fade-in mt-8 md:mt-12">
    <div class="mb-12">
      <h1 class="text-3xl font-bold mb-4 dark:text-gray-100 tracking-tight">
        Notes
      </h1>
      <p class="text-gray-600 dark:text-gray-400">
        A digital garden where I share my thoughts, experiments, and technical
        logs.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        notes.map((note) => {
          // Strip trailing /index or index from the ID since it maps to physical files
          const slug = note.id.replace(/\/index$|^index$/, "");
          const date = note.data.date;

          return (
            <a
              href={`/notes/${slug}`}
              class="block p-6 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-[#1a1a1a]"
            >
              <article class="flex flex-col h-full">
                <time
                  datetime={date.toISOString()}
                  class="text-sm font-semibold text-gray-500 dark:text-gray-400 mb-3"
                >
                  {date.toLocaleDateString("en-US", {
                    month: "long",
                    day: "numeric",
                    year: "numeric",
                  })}
                </time>

                <h2 class="text-xl font-bold mb-3 text-gray-900 dark:text-gray-100 font-serif leading-snug">
                  {note.data.title}
                </h2>

                {note.data.description && (
                  <p class="text-base text-gray-600 dark:text-gray-400 leading-relaxed font-serif">
                    {note.data.description}
                  </p>
                )}
              </article>
            </a>
          );
        })
      }
    </div>
  </section>
</Layout>

<style>
  .animate-fade-in {
    animation: fadeIn 0.5s ease-out forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
