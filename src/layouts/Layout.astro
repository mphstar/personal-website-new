---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const {
	title,
	description = "Bintang Malindo Eka Putra (Mphstar) - Software Developer based in Indonesia specializing in web and mobile applications.",
	image = "/assets/pp.png",
} = Astro.props;

const canonicalURL = new URL(
	Astro.url.pathname,
	Astro.site || "https://mphstar.my.id",
);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta
			name="keywords"
			content="Mphstar, Bintang Malindo Eka Putra, Software Developer, Web Developer, Mobile Developer, Frontend, Backend, Indonesia, Portfolio"
		/>
		<meta name="author" content="Bintang Malindo Eka Putra" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalURL} />

		<!-- OpenGraph Tags -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, canonicalURL)} />

		<!-- Twitter Tags -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, canonicalURL)} />

		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
		<ClientRouter />
	</head>
	<body
		class="bg-[#fcfcfc] dark:bg-[#111] text-[#111] dark:text-gray-200 font-sans antialiased leading-relaxed max-w-2xl mx-auto px-6 transition-colors duration-300"
	>
		<script is:inline>
			function applyTheme() {
				const theme = (() => {
					if (
						typeof localStorage !== "undefined" &&
						localStorage.getItem("theme")
					) {
						return localStorage.getItem("theme");
					}
					if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
						return "dark";
					}
					return "light";
				})();

				if (theme === "light") {
					document.documentElement.classList.remove("dark");
				} else {
					document.documentElement.classList.add("dark");
				}
				window.localStorage.setItem("theme", theme);
			}

			applyTheme();

			document.addEventListener("astro:after-swap", applyTheme);
		</script>

		<header
			class="flex justify-between items-start sticky top-0 bg-[#fcfcfc] dark:bg-[#111] z-40 pt-8 mb-12 border-b border-gray-200 dark:border-gray-800 pb-6 transition-colors duration-300"
		>
			<div>
				<h1 class="text-xl font-semibold mb-4">
					<a href="/" class="hover:underline">Mphstar.</a>
				</h1>
				<nav
					class="flex gap-4 text-sm font-medium text-gray-600 dark:text-gray-400"
				>
					<a
						href="/"
						class="hover:text-black dark:hover:text-white hover:underline transition-colors"
						>Home</a
					>
					<a
						href="/portfolio"
						class="hover:text-black dark:hover:text-white hover:underline transition-colors"
						>Portfolio</a
					>
					<a
						href="/achievements"
						class="hover:text-black dark:hover:text-white hover:underline transition-colors"
						>Achievements</a
					>
					<a
						href="/notes"
						class="hover:text-black dark:hover:text-white hover:underline transition-colors"
						>Notes</a
					>
				</nav>
			</div>

			<button
				id="themeToggle"
				class="p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
				aria-label="Toggle theme"
			>
				<svg
					id="sun-icon"
					class="w-5 h-5 hidden dark:block"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					><path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
					></path></svg
				>
				<svg
					id="moon-icon"
					class="w-5 h-5 block dark:hidden"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					><path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
					></path></svg
				>
			</button>
		</header>

		<script>
			// @ts-nocheck
			function initThemeToggle() {
				const handleToggleClick = () => {
					const element = document.documentElement;
					element.classList.toggle("dark");
					const isDark = element.classList.contains("dark");
					localStorage.setItem("theme", isDark ? "dark" : "light");
				};

				const toggleBtn = document.getElementById("themeToggle");
				if (toggleBtn) {
					toggleBtn.removeEventListener("click", handleToggleClick);
					toggleBtn.addEventListener("click", handleToggleClick);
				}
			}

			// Minimal Gallery Logic
			function initMinimalGallery() {
				const triggers = document.querySelectorAll(".gallery-trigger");
				const lightbox = document.getElementById("minimal-lightbox");
				const lightboxImg = document.getElementById(
					"minimal-lightbox-img",
				);
				const closeBtn = document.getElementById(
					"minimal-lightbox-close",
				);
				const prevBtn = document.getElementById(
					"minimal-lightbox-prev",
				);
				const nextBtn = document.getElementById(
					"minimal-lightbox-next",
				);

				if (!lightbox || triggers.length === 0) return;

				let galleryItems = [];
				let currentIndex = 0;

				function openLightbox(index) {
					currentIndex = index;
					updateImage();
					lightbox.classList.remove(
						"opacity-0",
						"pointer-events-none",
					);
				}

				function closeLightbox() {
					lightbox.classList.add("opacity-0", "pointer-events-none");
				}

				function updateImage() {
					if (galleryItems.length > 0) {
						lightboxImg.style.opacity = "0";
						setTimeout(() => {
							lightboxImg.src = galleryItems[currentIndex];
							lightboxImg.style.opacity = "1";
						}, 150);
					}
				}

				function nextImage(e) {
					if (e) e.stopPropagation();
					if (galleryItems.length > 1) {
						currentIndex = (currentIndex + 1) % galleryItems.length;
						updateImage();
					}
				}

				function prevImage(e) {
					if (e) e.stopPropagation();
					if (galleryItems.length > 1) {
						currentIndex =
							(currentIndex - 1 + galleryItems.length) %
							galleryItems.length;
						updateImage();
					}
				}

				// Reset state
				galleryItems = Array.from(triggers).map(
					(t) => t.getAttribute("href") || t.getAttribute("data-img"),
				);

				// Bind clicks (we don't cloneNode because astro:page-load handles clean scopes)
				triggers.forEach((trigger, idx) => {
					trigger.addEventListener("click", (e) => {
						e.preventDefault();
						openLightbox(idx);
					});
				});

				// Bind close logic
				lightbox.addEventListener("click", closeLightbox);
				if (closeBtn) closeBtn.addEventListener("click", closeLightbox);
				if (lightboxImg)
					lightboxImg.addEventListener("click", (e) =>
						e.stopPropagation(),
					);
				if (nextBtn) nextBtn.addEventListener("click", nextImage);
				if (prevBtn) prevBtn.addEventListener("click", prevImage);
			}

			// We use astro:page-load to run on initial load AND every client-side navigation
			document.addEventListener("astro:page-load", () => {
				if (localStorage.getItem("theme") === "dark") {
					document.documentElement.classList.add("dark");
				}
				initThemeToggle();
				initMinimalGallery();
			});
		</script>

		<main class="space-y-12">
			<slot />
		</main>
		<footer
			class="mt-16 pt-8 pb-12 md:pb-20 border-t border-gray-200 dark:border-gray-800 text-sm text-gray-500 transition-colors duration-300"
		>
			<p>
				&copy; {new Date().getFullYear()} Mphstar. All rights reserved.
			</p>
		</footer>

		<!-- Minimal Lightbox Overlay -->
		<div
			id="minimal-lightbox"
			class="fixed inset-0 z-50 bg-black/70 dark:bg-black/80 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 backdrop-blur-md"
		>
			<button
				id="minimal-lightbox-close"
				class="absolute top-6 right-6 p-2 text-white/70 hover:text-white transition-colors"
				aria-label="Close"
			>
				<svg
					class="w-8 h-8"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					><path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="1.5"
						d="M6 18L18 6M6 6l12 12"></path></svg
				>
			</button>

			<button
				id="minimal-lightbox-prev"
				class="absolute left-4 md:left-8 p-4 text-white/50 hover:text-white transition-colors"
				aria-label="Previous"
			>
				<svg
					class="w-8 h-8"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					><path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="1.5"
						d="M15 19l-7-7 7-7"></path></svg
				>
			</button>

			<img
				id="minimal-lightbox-img"
				src=""
				alt="Gallery Image"
				class="max-h-[85vh] max-w-[85vw] object-contain rounded-lg shadow-2xl transition-all duration-300 transform scale-95"
			/>

			<button
				id="minimal-lightbox-next"
				class="absolute right-4 md:right-8 p-4 text-white/50 hover:text-white transition-colors"
				aria-label="Next"
			>
				<svg
					class="w-8 h-8"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					><path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="1.5"
						d="M9 5l7 7-7 7"></path></svg
				>
			</button>
		</div>
	</body>
</html>
<style is:global>
	:root {
		--font-sans:
			"Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
			Helvetica, Arial, sans-serif;
	}
	body {
		font-family: var(--font-sans);
	}
</style>
